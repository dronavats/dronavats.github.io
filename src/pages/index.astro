---
import PostPreview from "@/components/blog/PostPreview.astro";
import SocialList from "@/components/SocialList.astro";
import { getAllPosts } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

// Posts
const MAX_POSTS = 10;
const allPosts = await getAllPosts();
// We sort and slice without the explicit <"post"> cast to avoid the Fragment error
const latestPosts = allPosts.sort(collectionDateSort).slice(0, MAX_POSTS);
---

<PageLayout meta={{ title: "Home" }}>
	<section>
		<h2 class="title mb-12">About</h2>
		<p class="mb-4">
			Hi! I’m a McDonald Institute Theory Fellow in the Department of Physics at Carleton University where 
I work on Beyond Standard Model (BSM) phenomenology. 
My current research interests are broadly focused on the field of Particle Astrophysics, 
and investigating problems at the intersection of particle physics and cosmology 
that shed light on better understanding the neutrino sector, the nature and origin of dark matter, 
and the baryon asymmetry of the universe.
		</p>
		<p class="mb-4">
			Before starting at Carleton, I completed my PhD at the University of Valencia 
and Instituto de Física Corpuscular (IFIC), 
where I worked on non-minimal extensions of the Standard Model, 
in particular, extended dark sectors with multiple and asymmetric components, 
as well as new neutrino mass models from extended scalar sectors.
		</p>
		<SocialList />
	</section>

	<section class="mt-16">
		<h2 class="title mb-6 text-xl text-accent">
			<a href="/posts/">Posts</a>
		</h2>
		<ul class="space-y-4" role="list">
			{
				latestPosts.map((p) => (
					<li class="grid gap-1 sm:grid-cols-[auto_1fr]">
						<PostPreview post={p} />
					</li>
				))
			}
		</ul>
	</section>
</PageLayout>
